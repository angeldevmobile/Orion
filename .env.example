# Orion AI Configuration
# Copia este archivo como .env y rellena tus keys

# --- Proveedor principal (Claude) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Proveedor alternativo (OpenAI) ---
OPENAI_API_KEY=sk-...

# --- Preferencia de proveedor: claude | openai | auto (default: auto) ---
AI_MODEL=auto

# --- Modelo a usar (requerido si no usas ai.set_model() en tu código) ---
# Anthropic: claude-haiku-4-5-20251001 | claude-sonnet-4-6 | claude-opus-4-7
# OpenAI:    gpt-4o-mini | gpt-4o | gpt-4-turbo
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
