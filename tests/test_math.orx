fn test_suma() {
    assert_eq(1 + 1, 2, "suma básica")
    assert_eq(10 + 5, 15, "suma positivos")
}

fn test_resta() {
    assert_eq(10 - 3, 7, "resta básica")
    assert_eq(0 - 5, -5, "resta negativo")
}

fn test_multiplicacion() {
    assert_eq(3 * 4, 12, "multiplicacion")
    assert_eq(0 * 999, 0, "mult por cero")
}

fn test_division() {
    result = 10 / 2
    assert(result == 5.0, "division exacta")
}
